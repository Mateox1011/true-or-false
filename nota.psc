Algoritmo nota
	definir not Como Real
	Escribir "ingrese la nota"
	Imprimir not
	si not<3.0 Entonces 
		Imprimir "insuficente" 
	SiNo  
	FinSi
	si not>3.0 y not<=3.5 Entonces
		Imprimir "aceptable"
	SiNo
	FinSi 
	si not<=4.0 y not>=3.5 Entonces
		Imprimir "sobresaliente"
	SiNo 
	FinSi
	si not<=5.0 y not>4.0
		Imprimir "excelente"
	FinSi
	
FinAlgoritmo
