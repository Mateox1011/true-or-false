Algoritmo sistema_operativo 
	Definir opci Como Caracter 
	Escribir "escriba un caracter"
	Leer opci
	Imprimir "si opcion es"
	si (opci=="a") o (opcion=="A") Entonces
		Imprimir "Android"  
	SiNo 
		si (opci=="i") o (opcion=="I") Entonces 
			Imprimir "IOS"
		SiNo
			Imprimir "invalido"
		FinSi
	FinSi
		

	
FinAlgoritmo
