Algoritmo numero_intervalo 
	Definir n1,n2,n3,valormax, valormin Como Real 
	Escribir "ingrese el valor del numero1"
	Leer n1
	Escribir "ingrese el valor del numero2"
	Leer n2
	Escribir "ingrese el valor del numero3"
	Leer n3
	valormin=n1
	valormax=n2
	si n3>=valormin y n3<=valormax Entonces
		Imprimir "entra en el intervalo"
	SiNo
		Imprimir "no entra en el intervalo"
	FinSi
FinAlgoritmo
